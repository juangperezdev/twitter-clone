# Database (default settings for docker-compose.yml)
DATABASE_URL="postgresql://twitter:twitter123@localhost:5432/twitter_clone"

# Session encryption key (Must be at least 32 chars)
# Generate one with: openssl rand -base64 32
SESSION_SECRET="your-secret-key-here-please-change-to-something-long-and-secure"

# Vercel Blob Storage (Auto-configured in Vercel. Not strictly needed for local dev: fallbacks to /public/uploads)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
